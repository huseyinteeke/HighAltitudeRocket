#ifndef SIT_SUT_SIT_SUT_H_
#define SIT_SUT_SIT_SUT_H_


#include "stm32f407xx.h"


extern const uint8_t commstarted;
extern const uint8_t sitheader;
extern const uint8_t sitfooter1;
extern const uint8_t sitfooter2;

#define SITACTIVECODE   2U
#define SUTACTIVECODE   1U
#define STOPSITSUT      3U



typedef struct __attribute__((packed)){
    uint8_t header;
    float height;
    float pressure;
    float accelx;
    float accely;
    float accelz;
    float gyrox;
    float gyroy;
    float gyroz;
    uint8_t checksum;
    uint8_t footer1;
    uint8_t footer2;
}SUT_DataRx_t;

typedef union{
    SUT_DataRx_t floatversion;
    uint8_t charversion[sizeof(SUT_DataRx_t)];
}SUT_DataUnion_t;

typedef struct __attribute__((packed)){
    uint8_t header;
    uint8_t command;
    uint8_t checksum;
    uint8_t footer1;
    uint8_t footer2;
}SitSut_DataHeader_t;

extern const SitSut_DataHeader_t SitStart;
extern const SitSut_DataHeader_t SutStart;
extern const SitSut_DataHeader_t SitSutStop;

typedef struct __attribute__((packed)){
    uint8_t header;
    float height;   //meters
    float pressure; //mBar
    float accelx;   //m/s^2
    float accely;   //m/s^2
    float accelz;   //m/s^2
    float gyrox;   //m/s^2
    float gyroy;   //m/s^2
    float gyroz;   //m/s^2
    uint8_t checksum;
    uint8_t footer1;
    uint8_t footer2;
}SIT_DataTx_t;


typedef union{
  SIT_DataTx_t floatversion;
  char charversion[sizeof(SIT_DataTx_t)];
}SIT_DataUnion_t;


typedef struct __attribute__((packed)) {
  uint8_t header;
  uint8_t data1;
  uint8_t data2;
  uint8_t checksum;
  uint8_t footer1;
  uint8_t footer2;
}SUT_StatusTypedef_t;

extern SUT_StatusTypedef_t SUTstatus;

uint8_t compareStartStop(SitSut_DataHeader_t* startstop);
uint8_t calculateChecksum(uint32_t sum);

#endif /* SIT_SUT_SIT_SUT_H_ */
